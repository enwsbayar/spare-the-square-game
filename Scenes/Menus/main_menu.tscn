theme_override_colors/font_color = Color(1, 1, 1, 1)
theme_override_colors/font_hover_color = Color(0.25, 0.9, 0.35, 1)
theme_override_colors/font_pressed_color = Color(0.2, 0.7, 0.3, 1)
text = "PLAY"
flat = true

[node name="ContinueButton" type="Button" parent="Center/VBox"]

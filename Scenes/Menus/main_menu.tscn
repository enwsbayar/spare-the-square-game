[gd_scene format=4 uid="uid://bmainmenu0001"]

[ext_resource type="Script" path="res://Scripts/main_menu.gd" id="1_script"]
[ext_resource type="FontFile" uid="uid://br2ax5etbni52" path="res://Fonts/PressStart2P-Regular.ttf" id="2_font"]

[node name="MainMenu" type="Control"]
script = ExtResource("1_script")
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="Background" type="ColorRect" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.05, 0.05, 0.07, 1)

[node name="Center" type="CenterContainer" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBox" type="VBoxContainer" parent="Center"]
layout_mode = 2
theme_override_constants/separation = 18

[node name="Title" type="Label" parent="Center/VBox"]
layout_mode = 2
theme_override_fonts/font = ExtResource("2_font")
theme_override_font_sizes/font_size = 22
theme_override_colors/font_color = Color(0.25, 0.9, 0.35, 1)
text = "SPARE THE SQUARE"
horizontal_alignment = 1

[node name="Spacer" type="Control" parent="Center/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 24)

[node name="PlayButton" type="Button" parent="Center/VBox"]
